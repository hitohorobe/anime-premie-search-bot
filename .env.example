# ローカル実行用の環境変数テンプレート。
# `.env` という名前でこのファイルをコピーし、値を埋めてください（.envはgitignore済み）。
# cp .env.example .env

# 記事本文からのイベント情報抽出に必須（未設定だと新規記事の抽出がスキップされる）
ANTHROPIC_API_KEY=

# 抽出に使うモデル（省略可、デフォルト claude-haiku-4-5）
# LLM_MODEL=claude-haiku-4-5

# animatetimesの一覧ページを何ページまで巡回するか（省略可、デフォルト30）
# 実行時に --max-pages N を指定するとこちらより優先される
# ANIMATETIMES_MAX_PAGES=30

# X (Twitter) への投稿（未設定ならXへの投稿はスキップされる）
# X_API_KEY=
# X_API_SECRET=
# X_ACCESS_TOKEN=
# X_ACCESS_TOKEN_SECRET=

# Bluesky への投稿（未設定ならBlueskyへの投稿はスキップされる）
# BLUESKY_HANDLE=
# BLUESKY_APP_PASSWORD=

# Google Calendar 連携（未設定ならスキップされる）
# サービスアカウントのJSONキーファイルの内容をそのまま1行で貼り付ける
# GOOGLE_SERVICE_ACCOUNT_JSON=
# GCAL_CALENDAR_ID=
